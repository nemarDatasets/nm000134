* annex.backend=MD5E
**/.git* annex.largefiles=nothing
*.bval annex.largefiles=nothing
*.bvec annex.largefiles=nothing
*.json annex.largefiles=nothing
*.tsv annex.largefiles=nothing
.bidsignore annex.largefiles=nothing
.gitignore annex.largefiles=nothing
CHANGES annex.largefiles=nothing
README annex.largefiles=nothing
README.md annex.largefiles=nothing
LICENSE annex.largefiles=nothing
*.py annex.largefiles=nothing
# Stimuli (JPGs) go through git-annex so the binaries land on nemar-s3
# rather than bloating the GitHub repo.
*.jpg annex.largefiles=anything
*.png annex.largefiles=anything
